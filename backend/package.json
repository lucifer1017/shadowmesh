{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test-ai": "tsx src/test.ts",
    "gen:keys": "cd .. && openssl genpkey -algorithm ed25519 -out buyer-private.pem && openssl genpkey -algorithm ed25519 -out seller-private.pem",
    "build:axl": "cd ../axl && set GOTOOLCHAIN=go1.25.5&& go build -o axl-node.exe ./cmd/node/",
    "dev:axl-buyer": "cd ../axl && axl-node.exe -config ../buyer-config.json",
    "dev:axl-seller": "cd ../axl && axl-node.exe -config ../seller-config.json",
    "dev:buyer": "dotenv -e .env.buyer tsx watch src/agents/buyer.ts",
    "dev:seller": "dotenv -e .env.seller tsx watch src/agents/seller.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}